# Server
PORT=3000
# Comma-separated allowed origins (Vercel production + previews)
FRONTEND_URL=https://your-frontend.vercel.app
BYPASS_SUBSCRIPTION=false
ADMIN_API_KEY=replace_with_long_random_string
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Notifications (SMTP - Brevo)
NOTIFICATIONS_ENABLED=true
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_login
SMTP_PASS=your_brevo_smtp_key
SMTP_SECURE=false
EMAIL_FROM=GreenGive <your-verified-email@example.com>
EMAIL_REPLY_TO=your-verified-email@example.com
EMAIL_ADMIN=your-verified-email@example.com

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# Database (Supabase Postgres connection string)
DATABASE_URL=postgresql://postgres:password@db.project.supabase.co:5432/postgres
